---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import categories from '../notion-categories.json';

// Aggregate all articles from all categories
const allPosts: { post: any; categorySlug: string; categoryDir: string }[] = [];
for (const { dir, slug } of categories) {
	const posts = await getCollection(slug as any);
	for (const post of posts) {
		allPosts.push({ post, categorySlug: slug, categoryDir: dir });
	}
}
allPosts.sort((a, b) => b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.page-header {
				text-align: center;
				margin-bottom: 2em;
			}
			.page-header h1 {
				font-size: 2em;
				margin-bottom: 0.1em;
			}
			.page-header p {
				color: rgb(var(--gray));
				font-size: 0.95em;
			}
			.article-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.article-list li {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.article-list li:last-child {
				border-bottom: none;
			}
			.article-list a {
				display: block;
				padding: 1.3em 0;
				text-decoration: none;
				transition: background 0.2s;
			}
			.article-list a:hover {
				background: rgba(var(--gray-light), 0.3);
				margin: 0 -1em;
				padding: 1.3em 1em;
				border-radius: 8px;
			}
			.article-title {
				margin: 0 0 0.3em 0;
				color: rgb(var(--black));
				font-size: 1.15em;
				line-height: 1.4;
			}
			.article-meta {
				color: rgb(var(--gray));
				font-size: 0.83em;
				display: flex;
				align-items: center;
				gap: 0.6em;
			}
			.cat-label {
				padding: 0.1em 0.5em;
				background: var(--accent);
				color: white;
				border-radius: 3px;
				font-size: 0.85em;
			}
			.article-desc {
				color: rgb(var(--gray-dark));
				font-size: 0.9em;
				margin-top: 0.3em;
				line-height: 1.6;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>好读</h1>
				<p>全部 {allPosts.length} 篇 · 在信息过载的时代，只读值得读的</p>
			</div>
			<ul class="article-list">
				{
					allPosts.map(({ post, categorySlug, categoryDir }) => (
						<li>
							<a href={`/${categorySlug}/${post.id}/`}>
								<h3 class="article-title">{post.data.title}</h3>
								<div class="article-meta">
									<span class="cat-label">{categoryDir}</span>
									<FormattedDate date={post.data.pubDate} />
								</div>
								{post.data.description && (
									<p class="article-desc">{post.data.description}</p>
								)}
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
