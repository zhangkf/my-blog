---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import categories from '../notion-categories.json';

// Kami-palette category colors — warm tones that sit on parchment
const CATEGORY_COLORS: Record<string, string> = {
	'AI': '#1B365D',           // ink blue (primary)
	'一人一Agent': '#2d6a5a',  // pine green
	'Misc': '#8a7e6b',         // warm gray
};
const COLOR_POOL = ['#6b4c3b', '#4a5568', '#7c5e3c', '#3d6b5e', '#5b4a7a', '#8b5c34'];
let colorIdx = 0;
function getCategoryColor(dir: string): string {
	if (CATEGORY_COLORS[dir]) return CATEGORY_COLORS[dir];
	const color = COLOR_POOL[colorIdx % COLOR_POOL.length];
	CATEGORY_COLORS[dir] = color;
	colorIdx++;
	return color;
}

// Aggregate all articles from all categories
const allPosts: { post: any; categorySlug: string; categoryDir: string }[] = [];
for (const { dir, slug } of categories) {
	const posts = await getCollection(slug as any);
	for (const post of posts) {
		allPosts.push({ post, categorySlug: slug, categoryDir: dir });
	}
}
allPosts.sort((a, b) => b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.page-header {
				text-align: left;
				margin-bottom: 1.5em;
			}
			.page-header h1 {
				font-size: 2em;
				margin-bottom: 0.15em;
				color: var(--accent);
			}
			.page-header p {
				color: rgb(var(--gray));
				font-size: 0.92em;
			}
			.article-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.article-list li {
				border-bottom: 1px solid var(--border-faint);
			}
			.article-list li:last-child {
				border-bottom: none;
			}
			.article-list a {
				display: block;
				padding: 1.5em 0.8em;
				margin: 0 -0.8em;
				text-decoration: none;
				border-radius: 6px;
				transition: background 0.2s;
			}
			.article-list a:hover {
				background: var(--surface-hover);
			}
			.article-title {
				margin: 0 0 0.4em 0;
				color: rgb(var(--black));
				font-size: 1.15em;
				font-weight: 500;
				line-height: 1.4;
			}
			.article-list a:hover .article-title {
				color: var(--accent);
			}
			.article-meta {
				color: rgb(var(--gray));
				font-size: 0.82em;
				display: flex;
				align-items: center;
				gap: 0.7em;
			}
			.cat-label {
				display: inline-block;
				padding: 0.1em 0.55em;
				color: #f5f4ed;
				border-radius: 3px;
				font-size: 0.82em;
				font-weight: 500;
				letter-spacing: 0.02em;
			}
			.article-desc {
				color: rgb(var(--gray-dark));
				font-size: 0.9em;
				margin-top: 0.4em;
				line-height: 1.55;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>好读</h1>
				<p>全部 {allPosts.length} 篇 · 在信息过载的时代，只读值得读的</p>
			</div>
			<ul class="article-list">
				{
					allPosts.map(({ post, categorySlug, categoryDir }) => (
						<li>
							<a href={`/${categorySlug}/${post.id}/`}>
								<h3 class="article-title">{post.data.title}</h3>
								<div class="article-meta">
									<span class="cat-label" style={`background:${getCategoryColor(categoryDir)}`}>{categoryDir}</span>
									<FormattedDate date={post.data.pubDate} />
								</div>
								{post.data.description && (
									<p class="article-desc">{post.data.description}</p>
								)}
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
