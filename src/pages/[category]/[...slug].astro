---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import categories from '../../notion-categories.json';

export async function getStaticPaths() {
	const paths = [];
	for (const { dir, slug } of categories) {
		const posts = await getCollection(slug as any);
		for (const post of posts) {
			paths.push({
				params: { category: slug, slug: post.id },
				props: { post, categoryDir: dir, categorySlug: slug },
			});
		}
	}
	return paths;
}

const { post, categoryDir, categorySlug } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage } = post.data;
const { Content } = await render(post);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.category-tag {
				display: inline-block;
				padding: 0.2em 0.6em;
				background: rgb(var(--accent));
				color: white;
				border-radius: 4px;
				font-size: 0.8rem;
				margin-bottom: 0.5em;
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && (
						typeof heroImage === 'string'
							? <img width={1020} height={510} src={heroImage} alt="" />
							: <img width={1020} height={510} src={heroImage.src} alt="" />
					)}
				</div>
				<div class="prose">
					<div class="title">
						<a href={`/${categorySlug}/`} class="category-tag">{categoryDir}</a>
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<Content />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
