---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import categories from '../../notion-categories.json';

export async function getStaticPaths() {
	const paths = [];
	for (const { dir, slug } of categories) {
		const posts = await getCollection(slug as any);
		for (const post of posts) {
			paths.push({
				params: { category: slug, slug: post.id },
				props: { post, categoryDir: dir, categorySlug: slug },
			});
		}
	}
	return paths;
}

const { post, categoryDir, categorySlug } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage } = post.data;
const { Content } = await render(post);
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.prose {
				width: 680px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.article-header {
				margin-bottom: 2em;
				padding-bottom: 1.5em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.article-header h1 {
				font-size: 1.8em;
				line-height: 1.4;
				margin: 0.3em 0 0.5em 0;
			}
			.article-meta {
				color: rgb(var(--gray));
				font-size: 0.9em;
				display: flex;
				align-items: center;
				gap: 0.8em;
				flex-wrap: wrap;
			}
			.category-tag {
				display: inline-block;
				padding: 0.15em 0.6em;
				background: var(--accent);
				color: white;
				border-radius: 3px;
				font-size: 0.8em;
				text-decoration: none;
				font-style: normal;
			}
			.category-tag:hover {
				background: var(--accent-dark);
				color: white;
			}
			.hero-image {
				margin-bottom: 2em;
			}
			.hero-image img {
				display: block;
				width: 100%;
				max-height: 400px;
				object-fit: cover;
				border-radius: 6px;
			}
			@media (max-width: 720px) {
				.article-header h1 {
					font-size: 1.4em;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="article-header">
						<div class="article-meta">
							<a href={`/${categorySlug}/`} class="category-tag">{categoryDir}</a>
							<FormattedDate date={pubDate} />
						</div>
						<h1>{title}</h1>
					</div>
					{heroImage && (
						<div class="hero-image">
							<img src={typeof heroImage === 'string' ? heroImage : heroImage.src} alt={title} />
						</div>
					)}
					<Content />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
