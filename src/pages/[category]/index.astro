---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import categories from '../../notion-categories.json';

export function getStaticPaths() {
	return categories.map(({ dir, slug }) => ({
		params: { category: slug },
		props: { dir, slug },
	}));
}

const { dir, slug } = Astro.props;
const posts = (await getCollection(slug as any)).sort(
	(a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${dir} | ${SITE_TITLE}`} description={`${dir} 分类下的所有文章`} />
		<style>
			.page-title {
				text-align: center;
				margin-bottom: 2em;
			}
			.page-title h1 {
				margin: 0 0 0.2em 0;
			}
			.page-title .count {
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.article-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.article-list li {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.article-list li:last-child {
				border-bottom: none;
			}
			.article-list a {
				display: block;
				padding: 1.5em 0;
				text-decoration: none;
				transition: background 0.2s;
			}
			.article-list a:hover {
				background: rgba(var(--gray-light), 0.3);
				margin: 0 -1em;
				padding: 1.5em 1em;
				border-radius: 8px;
			}
			.article-title {
				margin: 0 0 0.3em 0;
				color: rgb(var(--black));
				font-size: 1.2em;
				line-height: 1.4;
			}
			.article-meta {
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			.article-desc {
				color: rgb(var(--gray-dark));
				font-size: 0.92em;
				margin-top: 0.4em;
				line-height: 1.6;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-title">
				<h1>{dir}</h1>
				<span class="count">共 {posts.length} 篇文章</span>
			</div>
			<ul class="article-list">
				{
					posts.map((post: any) => (
						<li>
							<a href={`/${slug}/${post.id}/`}>
								<h3 class="article-title">{post.data.title}</h3>
								<span class="article-meta">
									<FormattedDate date={post.data.pubDate} />
								</span>
								{post.data.description && (
									<p class="article-desc">{post.data.description}</p>
								)}
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
