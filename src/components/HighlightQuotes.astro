---
/**
 * HighlightQuotes — 加粗金句高亮
 *
 * 编辑约定：在 Notion 里把金句加粗（作者原意或编辑挑选均可）。
 * sync 会把加粗转成 <strong>，本组件把正文里所有 <strong> 包成 <mark>，
 * 配墨蓝点状下划线呈现；点击直达金句卡预览（复用 QuoteCard）。
 *
 * 不做任何「挑选 / 分布 / 算法补足」——金句完全由编辑控制。
 * 与 QuoteCard 通过 haodu:quote 事件解耦。仅文章页使用，无 UI、无 props。
 */
---

<style is:global>
	/* 全局：文章正文内的加粗金句。限定在 .prose 内避免影响其他页面。
	   文字不变色，仅墨蓝点状下划线；hover 一抹淡底纹作二次确认。 */
	.prose mark.haodu-quote {
		background: none;
		color: inherit;
		text-decoration: underline dotted var(--accent);
		text-decoration-thickness: 2px;
		text-underline-offset: 5px;
		cursor: pointer;
		-webkit-tap-highlight-color: transparent;
		transition: background-color 0.15s;
	}
	.prose mark.haodu-quote:hover {
		background-color: var(--surface-accent);
	}
	@media (hover: none) {
		/* 纯触屏设备无 hover：改用 active 按压反馈 */
		.prose mark.haodu-quote:active {
			background-color: var(--surface-accent);
		}
	}
</style>

<script is:inline>
(function () {
	/* 仅文章页执行：以 .prose 存在为守卫 */
	var prose = document.querySelector('.prose');
	if (!prose) return;

	/* 过短的加粗视为术语/标签（如「.env」「原文链接」「Level 0」），不高亮。
	   金句通常是有完整语义的句子，少有低于此长度的。 */
	var MIN_LEN = 12;

	/* 去掉首尾标点/空白后的纯文本长度（中文按字、英文按字符计） */
	function visibleLen(s) {
		return (s || '')
			.replace(/^[\s。，、；：！？“”‘’（）《》【】—…\-,.!?:/"'()]+/, '')
			.replace(/[\s。，、；：！？“”‘’（）《》【】—…\-,.!?:/"'()]+$/, '')
			.length;
	}

	/* 收集正文里的所有 <strong> / <b>，跳过标题区 */
	var strongs = prose.querySelectorAll('strong, b');
	var marks = [];
	for (var i = 0; i < strongs.length; i++) {
		var el = strongs[i];
		/* 跳过标题（h1-h6）内的加粗——那是标题样式，不当金句 */
		if (el.closest('h1, h2, h3, h4, h5, h6')) continue;
		/* 跳过文章头/标题区 */
		if (el.closest('.article-header')) continue;
		/* 跳过过短的加粗（术语/标签），只高亮足够长的金句 */
		if (visibleLen(el.textContent) < MIN_LEN) continue;

		var mark = document.createElement('mark');
		mark.className = 'haodu-quote';
		mark.setAttribute('data-quote', el.textContent.trim());
		/* 用 mark 包住 strong：保留加粗视觉效果，叠加点状下划线 */
		el.parentNode.insertBefore(mark, el);
		mark.appendChild(el);
		marks.push(mark);
	}

	if (!marks.length) return;

	/* ---- 点击高亮 → 分发 haodu:quote 事件（QuoteCard 接管） ---- */
	for (var m = 0; m < marks.length; m++) {
		(function (markEl) {
			markEl.addEventListener('click', function (e) {
				e.stopPropagation();                /* 不触发翻页模式 tap-zone */
				try { window.getSelection().removeAllRanges(); } catch (err) {}
				var q = markEl.getAttribute('data-quote') || markEl.textContent || '';
				document.dispatchEvent(new CustomEvent('haodu:quote', { detail: { quote: q } }));
			});
		})(marks[m]);
	}
})();
</script>
